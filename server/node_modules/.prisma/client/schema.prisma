// Depósito - Schema v1 (Fase 1: Drogas + Actas + Movimientos)
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USERS
// ============================================================
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role     @default(observador)
  createdAt    DateTime @default(now()) @map("created_at")

  actas       Acta[]
  movimientos Movimiento[]

  @@map("users")
}

enum Role {
  encargado
  observador
  solicitante
}

// ============================================================
// ACTAS
// ============================================================
model Acta {
  id        String     @id @default(uuid())
  fecha     DateTime   @db.Date
  createdBy String     @map("created_by")
  estado    EstadoActa @default(pendiente)
  notas     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user  User       @relation(fields: [createdBy], references: [id])
  items ActaItem[]

  @@map("actas")
}

enum EstadoActa {
  pendiente
  parcial
  completada
}

// ============================================================
// ACTA ITEMS
// ============================================================
model ActaItem {
  id                  String    @id @default(uuid())
  actaId              String    @map("acta_id")
  categoria           Categoria
  productoNombre      String    @map("producto_nombre")
  lote                String
  cantidadIngresada   Int       @map("cantidad_ingresada")
  cantidadDistribuida Int       @default(0) @map("cantidad_distribuida")
  createdAt           DateTime  @default(now()) @map("created_at")

  acta        Acta         @relation(fields: [actaId], references: [id], onDelete: Cascade)
  movimientos Movimiento[]

  @@map("acta_items")
}

enum Categoria {
  droga
  estuche
  etiqueta
  frasco
}

// ============================================================
// INVENTARIO DROGAS
// ============================================================
model InventarioDroga {
  id        String   @id @default(uuid())
  nombre    String   @unique
  cantidad  Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("inventario_drogas")
}

// ============================================================
// MOVIMIENTOS (auditoría)
// ============================================================
model Movimiento {
  id             String         @id @default(uuid())
  tipo           TipoMovimiento
  categoria      Categoria
  productoNombre String         @map("producto_nombre")
  cantidad       Int // positivo = ingreso, negativo = egreso
  referenciaId   String?        @map("referencia_id")
  justificacion  String?
  createdBy      String         @map("created_by")
  createdAt      DateTime       @default(now()) @map("created_at")

  user     User      @relation(fields: [createdBy], references: [id])
  actaItem ActaItem? @relation(fields: [referenciaId], references: [id])

  @@map("movimientos")
}

enum TipoMovimiento {
  ingreso_acta
  egreso_orden
  ajuste_manual
}
