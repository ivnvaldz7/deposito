# 🚀 Plataforma Unificada - Variables de Entorno

# Base de datos (PostgreSQL con schemas: platform, ale_bet, deposito)
PLATFORM_DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT - Access token (15 min)
PLATFORM_JWT_SECRET=un-string-largo-y-random-minimo-32-chars

# Google OAuth 2.0
GOOGLE_CLIENT_ID=tu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Bootstrap de superadmin inicial
# Configurar SOLO para la primera ejecución. Luego desactivar.
# BOOTSTRAP_KEY opcional: protege el endpoint en entornos compartidos.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=una-contrasena-segura
BOOTSTRAP_KEY=mi-clave-de-bootstrap

# Frontend URL (para CORS y redirects post-login)
FRONTEND_URL=http://localhost:5176

# Puerto del servidor (default 3000)
PORT=3000

# Entorno
NODE_ENV=development
