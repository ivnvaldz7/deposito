{
  "name": "@platform/server",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "db:migrate": "cd ../../../packages/db && npx prisma migrate deploy",
    "db:generate": "cd ../../../packages/db && npx prisma generate",
    "db:create-superadmin": "tsx src/scripts/create-superadmin.ts",
    "db:seed-users:staging": "tsx src/seed/seed-staging-users.ts",
    "db:seed-deposito": "tsx src/seed/seed-deposito.ts",
    "db:seed-ale-bet": "tsx src/seed/seed-ale-bet.ts",
    "db:setup": "npm run db:migrate && npm run db:generate && npm run db:seed-deposito && npm run db:seed-ale-bet && npm run db:create-superadmin"
  },
  "dependencies": {
    "@platform/core": "*",
    "@platform/db": "*",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.0",
    "jsonwebtoken": "^9.0.0",
    "pdfkit": "^0.16.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/pdfkit": "^0.13.0",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.4"
  }
}
