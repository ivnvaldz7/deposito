generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["platform", "ale_bet", "deposito"]
}

model PlatformUser {
  id        String      @id @default(cuid())
  email     String      @unique
  nombre    String
  password  String
  activo    Boolean     @default(true)
  estado    String      @default("pending")
  isPlatformAdmin Boolean @default(false)
  appAccess AppAccess[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@schema("platform")
}

model AppAccess {
  id        String       @id @default(cuid())
  userId    String
  user      PlatformUser @relation(fields: [userId], references: [id])
  app       AppId
  rol       String
  activo    Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@unique([userId, app])
  @@schema("platform")
}

enum AppId {
  deposito
  ale_bet
  portal
  admin

  @@schema("platform")
}

// ─── Ale-Bet schema ──────────────────────────────────────────────────────────

model Producto {
  id          String      @id @default(cuid())
  nombre      String
  sku         String      @unique
  stockMinimo Int         @default(100)
  activo      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  lotes       Lote[]
  itemsPedido ItemPedido[]

  @@schema("ale_bet")
}

model Lote {
  id               String    @id @default(cuid())
  numero           String
  productoId       String
  producto         Producto  @relation(fields: [productoId], references: [id])
  cajas            Int       @default(0)
  sueltos          Int       @default(0)
  fechaProduccion  DateTime
  fechaVencimiento DateTime
  activo           Boolean   @default(true)
  createdAt        DateTime  @default(now())

  @@unique([numero, productoId])
  @@schema("ale_bet")
}

model Cliente {
  id        String   @id @default(cuid())
  nombre    String   @unique
  contacto  String?
  direccion String?
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  pedidos   Pedido[]

  @@schema("ale_bet")
}

model Pedido {
  id         String       @id @default(cuid())
  numero     String       @unique
  clienteId  String
  cliente    Cliente      @relation(fields: [clienteId], references: [id])
  vendedorId String
  armadorId  String?
  estado     EstadoPedido @default(PENDIENTE)
  items      ItemPedido[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@schema("ale_bet")
}

model ItemPedido {
  id         String   @id @default(cuid())
  pedidoId   String
  pedido     Pedido   @relation(fields: [pedidoId], references: [id])
  productoId String
  producto   Producto @relation(fields: [productoId], references: [id])
  cantidad   Int
  completado Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@schema("ale_bet")
}

model MovimientoStock {
  id         String         @id @default(cuid())
  productoId String
  cantidad   Int
  tipo       TipoMovimiento
  referencia String?
  usuarioId  String
  createdAt  DateTime       @default(now())

  @@schema("ale_bet")
}

enum EstadoPedido {
  PENDIENTE
  APROBADO
  EN_ARMADO
  COMPLETADO
  CANCELADO

  @@schema("ale_bet")
}

enum TipoMovimiento {
  ENTRADA_MANUAL
  SALIDA_PEDIDO
  AJUSTE

  @@schema("ale_bet")
}

// ─── Deposito schema ────────────────────────────────────────────────────────
// Depósito - Schema v1 (Fase 1: Drogas + Actas + Movimientos)




// ============================================================
// USERS
// ============================================================
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String
  role         Role     @default(observador)
  platformUserId String? @unique @map("platform_user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  actas                  Acta[]
  movimientos            Movimiento[]
  insumoPendientes       InsumoPendiente[]
  ordenesComoSolicitante OrdenProduccion[] @relation("OrdenesComoSolicitante")
  ordenesComoAprobador   OrdenProduccion[] @relation("OrdenesComoAprobador")

  @@map("users")

  @@schema("deposito")
}

enum Role {
  encargado
  observador
  solicitante

  @@schema("deposito")
}

// ============================================================
// ACTAS
// ============================================================
model Acta {
  id        String     @id @default(uuid())
  fecha     DateTime   @db.Date
  createdBy String     @map("created_by")
  estado    EstadoActa @default(pendiente)
  notas     String?
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user  User       @relation(fields: [createdBy], references: [id])
  items ActaItem[]

  @@map("actas")

  @@schema("deposito")
}

enum EstadoActa {
  pendiente
  parcial
  completada

  @@schema("deposito")
}

// ============================================================
// ACTA ITEMS
// ============================================================
model ActaItem {
  id                  String    @id @default(uuid())
  actaId              String    @map("acta_id")
  productoId          String?   @map("producto_id")
  categoria           Categoria
  productoNombre      String    @map("producto_nombre")
  lote                String
  vencimiento         DateTime? @db.Date @map("vencimiento")
  temperaturaTransporte String? @map("temperatura_transporte")
  condicionEmbalaje   CondicionEmbalaje? @map("condicion_embalaje")
  observacionesCalidad String? @map("observaciones_calidad")
  aprobadoCalidad     Boolean   @default(false) @map("aprobado_calidad")
  cantidadIngresada   Int       @map("cantidad_ingresada")
  cantidadDistribuida Int       @default(0) @map("cantidad_distribuida")
  mercado             Mercado?  // solo para categoría estuche/etiqueta
  createdAt           DateTime  @default(now()) @map("created_at")

  acta     Acta      @relation(fields: [actaId], references: [id], onDelete: Cascade)
  producto DepositoProducto? @relation(fields: [productoId], references: [id])

  @@index([productoId])
  @@map("acta_items")

  @@schema("deposito")
}

enum Categoria {
  droga
  estuche
  etiqueta
  frasco

  @@schema("deposito")
}

enum Mercado {
  argentina
  colombia
  mexico
  ecuador
  bolivia
  paraguay
  no_exportable

  @@schema("deposito")
}

enum CondicionEmbalaje {
  bueno
  regular
  malo

  @@schema("deposito")
}

// ============================================================
// INVENTARIO DROGAS
// ============================================================
model InventarioDroga {
  id          String    @id @default(uuid())
  productoId  String?   @map("producto_id")
  nombre      String
  lote        String?
  vencimiento DateTime? @db.Date @map("vencimiento")
  cantidad    Int       @default(0)
  updatedAt   DateTime  @updatedAt @map("updated_at")

  producto DepositoProducto? @relation(fields: [productoId], references: [id])

  @@unique([nombre, lote])
  @@index([productoId])
  @@index([productoId, lote])
  @@map("inventario_drogas")

  @@schema("deposito")
}

// ============================================================
// INVENTARIO ESTUCHES
// ============================================================
model InventarioEstuche {
  id         String   @id @default(uuid())
  productoId String?  @map("producto_id")
  articulo   String
  mercado    Mercado
  cantidad   Int      @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  producto DepositoProducto? @relation(fields: [productoId], references: [id])

  @@unique([articulo, mercado])
  @@index([productoId])
  @@index([productoId, mercado])
  @@map("inventario_estuches")

  @@schema("deposito")
}

// ============================================================
// INVENTARIO ETIQUETAS
// ============================================================
model InventarioEtiqueta {
  id         String   @id @default(uuid())
  productoId String?  @map("producto_id")
  articulo   String
  mercado    Mercado
  cantidad   Int      @default(0)
  updatedAt  DateTime @updatedAt @map("updated_at")

  producto DepositoProducto? @relation(fields: [productoId], references: [id])

  @@unique([articulo, mercado])
  @@index([productoId])
  @@index([productoId, mercado])
  @@map("inventario_etiquetas")

  @@schema("deposito")
}

// ============================================================
// INVENTARIO FRASCOS
// ============================================================
model InventarioFrasco {
  id              String   @id @default(uuid())
  productoId      String?  @map("producto_id")
  articulo        String   @unique
  unidadesPorCaja Int      @map("unidades_por_caja")
  cantidadCajas   Int      @default(0) @map("cantidad_cajas")
  total           Int      @default(0)
  updatedAt       DateTime @updatedAt @map("updated_at")

  producto DepositoProducto? @relation(fields: [productoId], references: [id])

  @@index([productoId])
  @@map("inventario_frascos")

  @@schema("deposito")
}

// ============================================================
// MOVIMIENTOS (auditoría)
// ============================================================
model Movimiento {
  id             String         @id @default(uuid())
  tipo           DepositoTipoMovimiento
  categoria      Categoria
  productoNombre String         @map("producto_nombre")
  lote           String?
  cantidad       Int // positivo = ingreso, negativo = egreso
  referenciaId   String?        @map("referencia_id")
  referenciaTipo RefTipo?       @map("referencia_tipo")
  justificacion  String?
  createdBy      String         @map("created_by")
  createdAt      DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [createdBy], references: [id])

  @@map("movimientos")

  @@schema("deposito")
}

enum RefTipo {
  acta_item
  orden

  @@schema("deposito")
}

enum DepositoTipoMovimiento {
  ingreso_acta
  egreso_orden
  ajuste_manual

  @@schema("deposito")
}

// ============================================================
// INSUMOS PENDIENTES
// ============================================================
model InsumoPendiente {
  id                   String          @id @default(uuid())
  categoria            String          @default("frasco")
  articulo             String
  cantidad             Int
  destino              String
  estado               EstadoPendiente @default(en_esterilizacion)
  fechaEnvio           DateTime        @db.Date @map("fecha_envio")
  fechaRetornoEstimada DateTime?       @db.Date @map("fecha_retorno_estimada")
  fechaRecibido        DateTime?       @db.Date @map("fecha_recibido")
  notas                String?
  createdBy            String          @map("created_by")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")

  user User @relation(fields: [createdBy], references: [id])

  @@map("insumos_pendientes")

  @@schema("deposito")
}

enum EstadoPendiente {
  en_esterilizacion
  recibido

  @@schema("deposito")
}

// ============================================================
// ÓRDENES DE PRODUCCIÓN
// ============================================================
model OrdenProduccion {
  id             String      @id @default(uuid())
  solicitanteId  String      @map("solicitante_id")
  aprobadoPor    String?     @map("aprobado_por")
  productoId     String?     @map("producto_id")
  categoria      Categoria
  productoNombre String      @map("producto_nombre")
  mercado        Mercado?
  cantidad       Int
  urgencia       Urgencia    @default(normal)
  estado         EstadoOrden @default(solicitada)
  motivoRechazo  String?     @map("motivo_rechazo")
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  solicitante User      @relation("OrdenesComoSolicitante", fields: [solicitanteId], references: [id])
  aprobador   User?     @relation("OrdenesComoAprobador", fields: [aprobadoPor], references: [id])
  producto    DepositoProducto? @relation(fields: [productoId], references: [id])

  @@index([productoId])
  @@map("ordenes_produccion")

  @@schema("deposito")
}

enum Urgencia {
  normal
  urgente

  @@schema("deposito")
}

enum EstadoOrden {
  solicitada
  aprobada
  ejecutada
  completada
  rechazada

  @@schema("deposito")
}

// ============================================================
// CATÁLOGO DE PRODUCTOS
// ============================================================
model DepositoProducto {
  id             String    @id @default(uuid())
  nombreBase     String    @map("nombre_base")
  volumen        Decimal?  @db.Decimal(10, 3)
  unidad         String?
  variante       String?
  categoria      Categoria
  nombreCompleto String    @map("nombre_completo")
  activo         Boolean   @default(true)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  inventarioDrogas    InventarioDroga[]
  inventarioEstuches  InventarioEstuche[]
  inventarioEtiquetas InventarioEtiqueta[]
  inventarioFrascos   InventarioFrasco[]
  actaItems           ActaItem[]
  ordenes             OrdenProduccion[]

  @@unique([nombreCompleto, categoria])
  @@map("productos")

  @@schema("deposito")
}
