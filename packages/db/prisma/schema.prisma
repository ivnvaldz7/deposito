generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  output          = "../src/generated/client"
}

datasource db {
  provider = "postgresql"
  schemas  = ["platform"]
}

model PlatformUser {
  id        String      @id @default(cuid())
  email     String      @unique
  nombre    String
  password  String
  activo    Boolean     @default(true)
  isPlatformAdmin Boolean @default(false)
  appAccess AppAccess[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@schema("platform")
}

model AppAccess {
  id        String       @id @default(cuid())
  userId    String
  user      PlatformUser @relation(fields: [userId], references: [id])
  app       AppId
  rol       String
  activo    Boolean      @default(true)
  createdAt DateTime     @default(now())

  @@unique([userId, app])
  @@schema("platform")
}

enum AppId {
  deposito
  ale_bet

  @@schema("platform")
}
